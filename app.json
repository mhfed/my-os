{
  "expo": {
    "name": "Personal OS",
    "slug": "personal-os",
    "version": "1.0.0",
    "scheme": "personalos",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080812"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hieuminh.personalos",
      "infoPlist": {
        "UILaunchStoryboardName": "SplashScreen"
      }
    },
    "android": {
      "package": "com.hieuminh.personalos",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080812"
      }
    },
    "plugins": ["expo-router", "expo-font", "expo-sqlite", "expo-asset"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
